{
  "name": "snake-graphic",
  "private": true,
  "version": "1.0.0",
  "description": "霓虹风桌面与网页双端贪吃蛇项目，包含竞技征程、Boss 战、回放系统与 OJ C 语言版本。",
  "author": "Theater-ahyeon",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "desktop": "pnpm build && electron .",
    "desktop:run": "pnpm build && electron .",
    "desktop:pack": "pnpm build && electron-builder --win portable"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "studio.neonsnake.desktop",
    "productName": "Neon Snake Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Neon-Snake-Studio-${version}-portable.${ext}"
    }
  }
}
